# ============================================
# Quizora — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# All variables documented below.

# -------------------------------------------
# GEMINI AI API KEY (Required for AI quiz generation)
# -------------------------------------------
# Obtain from: https://aistudio.google.com/apikey
# Used by: POST /api/gemini/generate
GEMINI_API_KEY="your_gemini_api_key_here"

# -------------------------------------------
# JWT SECRET (Required for authentication)
# -------------------------------------------
# A strong random string used to sign and verify JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_jwt_secret_here"

# -------------------------------------------
# PORT (Optional, defaults to 3000)
# -------------------------------------------
# The port the Express server listens on.
PORT=3000

# -------------------------------------------
# NODE_ENV (Set automatically by deployment)
# -------------------------------------------
# Values: "development" | "production"
# NODE_ENV="production"
